<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_2" targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:process id="ForecastProcess" name="Прогнозирование закупок на основе продаж и отзывов" isExecutable="true">
    
    <bpmn:startEvent id="StartEvent" name="Инициация прогноза">
      <bpmn:outgoing>Flow_to_UserSelect</bpmn:outgoing>
    </bpmn:startEvent>
    
    <bpmn:userTask id="SelectParams" name="Менеджер выбирает период и категорию товаров">
      <bpmn:incoming>Flow_to_UserSelect</bpmn:incoming>
      <bpmn:outgoing>Flow_to_GetSales</bpmn:outgoing>
    </bpmn:userTask>
    
    <bpmn:serviceTask id="GetSales" name="Выгрузить исторические продажи из DWH (Core layer)">
      <bpmn:incoming>Flow_to_GetSales</bpmn:incoming>
      <bpmn:outgoing>Flow_to_GetSentiment</bpmn:outgoing>
    </bpmn:serviceTask>
    
    <bpmn:serviceTask id="GetSentiment" name="Получить среднюю тональность отзывов за период из Mart layer">
      <bpmn:incoming>Flow_to_GetSentiment</bpmn:incoming>
      <bpmn:outgoing>Flow_to_RunModel</bpmn:outgoing>
    </bpmn:serviceTask>
    
    <bpmn:serviceTask id="RunModel" name="Запустить модель прогноза (линейная регрессия + ARIMA)">
      <bpmn:incoming>Flow_to_RunModel</bpmn:incoming>
      <bpmn:outgoing>Flow_to_SaveForecast</bpmn:outgoing>
    </bpmn:serviceTask>
    
    <bpmn:serviceTask id="SaveForecast" name="Сохранить прогноз в витрину Mart (таблица forecast)">
      <bpmn:incoming>Flow_to_SaveForecast</bpmn:incoming>
      <bpmn:outgoing>Flow_to_Review</bpmn:outgoing>
    </bpmn:serviceTask>
    
    <bpmn:userTask id="ReviewForecast" name="Менеджер утверждает объёмы закупки">
      <bpmn:incoming>Flow_to_Review</bpmn:incoming>
      <bpmn:outgoing>Flow_to_End</bpmn:outgoing>
    </bpmn:userTask>
    
    <bpmn:endEvent id="EndEvent" name="Завершение прогноза">
      <bpmn:incoming>Flow_to_End</bpmn:incoming>
    </bpmn:endEvent>
    
    <!-- Sequence flows -->
    <bpmn:sequenceFlow id="Flow_to_UserSelect" sourceRef="StartEvent" targetRef="SelectParams" />
    <bpmn:sequenceFlow id="Flow_to_GetSales" sourceRef="SelectParams" targetRef="GetSales" />
    <bpmn:sequenceFlow id="Flow_to_GetSentiment" sourceRef="GetSales" targetRef="GetSentiment" />
    <bpmn:sequenceFlow id="Flow_to_RunModel" sourceRef="GetSentiment" targetRef="RunModel" />
    <bpmn:sequenceFlow id="Flow_to_SaveForecast" sourceRef="RunModel" targetRef="SaveForecast" />
    <bpmn:sequenceFlow id="Flow_to_Review" sourceRef="SaveForecast" targetRef="ReviewForecast" />
    <bpmn:sequenceFlow id="Flow_to_End" sourceRef="ReviewForecast" targetRef="EndEvent" />
  </bpmn:process>
  
  <bpmndi:BPMNDiagram id="BPMNDiagram_2">
    <bpmndi:BPMNPlane id="BPMNPlane_2" bpmnElement="ForecastProcess">
      <bpmndi:BPMNShape id="StartEvent_di" bpmnElement="StartEvent">
        <dc:Bounds x="80" y="100" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="SelectParams_di" bpmnElement="SelectParams">
        <dc:Bounds x="170" y="80" width="140" height="60" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="GetSales_di" bpmnElement="GetSales">
        <dc:Bounds x="370" y="80" width="140" height="60" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="GetSentiment_di" bpmnElement="GetSentiment">
        <dc:Bounds x="570" y="80" width="140" height="60" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="RunModel_di" bpmnElement="RunModel">
        <dc:Bounds x="770" y="80" width="140" height="60" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="SaveForecast_di" bpmnElement="SaveForecast">
        <dc:Bounds x="970" y="80" width="140" height="60" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ReviewForecast_di" bpmnElement="ReviewForecast">
        <dc:Bounds x="1170" y="80" width="140" height="60" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_di" bpmnElement="EndEvent">
        <dc:Bounds x="1370" y="100" width="36" height="36" />
      </bpmndi:BPMNShape>
      
      <bpmndi:BPMNEdge id="Edge_Start_Select" bpmnElement="Flow_to_UserSelect">
        <di:waypoint x="116" y="118" />
        <di:waypoint x="170" y="110" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Select_Sales" bpmnElement="Flow_to_GetSales">
        <di:waypoint x="310" y="110" />
        <di:waypoint x="370" y="110" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Sales_Sentiment" bpmnElement="Flow_to_GetSentiment">
        <di:waypoint x="510" y="110" />
        <di:waypoint x="570" y="110" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Sentiment_Model" bpmnElement="Flow_to_RunModel">
        <di:waypoint x="710" y="110" />
        <di:waypoint x="770" y="110" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Model_Save" bpmnElement="Flow_to_SaveForecast">
        <di:waypoint x="910" y="110" />
        <di:waypoint x="970" y="110" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Save_Review" bpmnElement="Flow_to_Review">
        <di:waypoint x="1110" y="110" />
        <di:waypoint x="1170" y="110" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Review_End" bpmnElement="Flow_to_End">
        <di:waypoint x="1310" y="110" />
        <di:waypoint x="1370" y="118" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
