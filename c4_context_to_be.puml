@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Context.puml

title Контекстная диаграмма – Целевая архитектура (TO BE) с ETL, DWH и BI

' Персоны
Person(customer, "Клиент", "Покупатель в интернет-магазине или офлайн-точке")
Person(analyst, "Аналитик данных", "Строит отчёты, прогнозы, дашборды")
Person(manager, "Менеджер", "Принимает решения на основе BI-отчётов")

' Существующие системы (объединены в одну группу для простоты)
System(existing, "Существующие системы", "Интернет-магазин, CRM, WMS, 1С (Торговля, ДС, ДО)")

' Новые системы целевой архитектуры
System(etl, "ETL-процесс (Extract, Transform, Load)", "Apache Airflow + Python, оркестрация")
System(dwh, "Хранилище данных (DWH)", "ClickHouse / PostgreSQL, централизованная аналитика")
System(bi, "BI-платформа", "Tableau / Power BI, визуализация и прогнозирование")

' Внешние системы
System_Ext(brand, "BrandAnalytics", "Мониторинг соцмедиа (отзывы, тональность)")

' Связи (пользователи)
Rel(customer, existing, "Взаимодействует (заказы, поддержка)", "HTTPS / телефон")
Rel(analyst, bi, "Работает с дашбордами, строит отчёты", "HTTP")
Rel(manager, bi, "Просматривает KPI, утверждает прогнозы", "HTTP")

' Связи между системами
Rel(existing, etl, "Выгружают операционные данные", "JDBC / REST API / файлы")
Rel(brand, etl, "Поставляет отзывы и тональность", "REST API (JSON)")

Rel(etl, dwh, "Загружает очищенные, нормализованные, объединённые данные")
Rel(dwh, bi, "Предоставляет данные для визуализации и прогнозов", "SQL / MDX / ODBC")

' Примечание о преимуществах
note right of dwh
  **Преимущества TO BE:**
  - Единое хранилище данных
  - Возможность кросс-функциональной аналитики
  - Прогнозирование спроса с учётом соцмедиа
  - BI-дашборды для всех уровней управления
end note

@enduml
