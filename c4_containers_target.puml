@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml

title Контейнерная диаграмма целевой архитектуры

Person(customer, "Клиент")

System_Boundary(target, "Целевая архитектура") {
    Container(web, "Web-сайт", "React")
    Container(mobile, "Мобильное приложение", "Kotlin/Swift")
    Container(crm, "CRM", "Java")
    Container(wms, "WMS", "C#")
    Container(ones_trade, "1С Торговля", "MS SQL")
    Container(ones_sd, "1С Денежные средства", "MS SQL")
    Container(ones_doc, "1С Документооборот", "MS SQL")
    
    Container(etl_server, "ETL-сервер", "Python + Apache Airflow", "Оркестрация, очистка, нормализация")
    ContainerDb(dwh, "Хранилище данных", "ClickHouse / PostgreSQL", "Факты и измерения, денормализованные витрины")
    Container(bi_server, "BI-сервер", "Tableau Server", "Визуализация, прогностика")
}

ContainerDb(social_ext, "BrandAnalytics", "Внешняя API")

Rel(web, etl_server, "Логи действий, заказы", "REST API")
Rel(mobile, etl_server, "Логи действий", "REST API")
Rel(crm, etl_server, "Данные клиентов", "JDBC")
Rel(wms, etl_server, "Остатки, движения", "JDBC")
Rel(ones_trade, etl_server, "Продажи, товары", "JDBC")
Rel(ones_sd, etl_server, "Финансовые транзакции", "JDBC")
Rel(social_ext, etl_server, "Отзывы, тональность", "API")
Rel(etl_server, dwh, "Загрузка в слои staging, core, mart")
Rel(dwh, bi_server, "SQL-запросы")

@enduml