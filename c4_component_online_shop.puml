@startuml
title Компонентная диаграмма интернет-магазина

component "Каталог" as catalog <<component>>
component "Корзина" as cart <<component>>
component "API заказов" as order_api <<component>>

database "База данных (PostgreSQL)\nТовары, пользователи, корзины" as db

catalog --> db : "Читает"
cart --> db : "Читает/пишет"
cart --> order_api : "Вызывает"
order_api --> db : "Сохраняет заказ"
order_api --> "ETL-процесс" : "Отправляет события (Kafka/HTTP)"

@enduml