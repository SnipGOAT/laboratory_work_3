@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml

title Контейнерная диаграмма текущей архитектуры

Person(customer, "Клиент")

System_Boundary(retail, "Розничное предприятие") {
    Container(web, "Web-сайт", "React, Node.js", "Каталог, корзина, оплата")
    Container(mobile, "Мобильное приложение", "Kotlin/Swift", "Заказы, уведомления")
    Container(crm_app, "CRM-система", "Java + PostgreSQL", "Управление клиентами, заявки")
    Container(wms_app, "WMS", "C# + MSSQL", "Складские операции, инвентаризация")
    ContainerDb(ones_trade_db, "1С Торговля", "MS SQL Server", "Товары, продажи, цены")
    ContainerDb(ones_sd_db, "1С Денежные средства", "MS SQL Server", "Платежи, касса")
    ContainerDb(ones_doc_db, "1С Документооборот", "MS SQL Server", "Договоры, накладные")
}

ContainerDb(social_ext, "BrandAnalytics", "Внешняя система", "Мониторинг соцмедиа")

Rel(customer, web, "Использует", "HTTPS")
Rel(customer, mobile, "Использует", "HTTPS")
Rel(web, ones_trade_db, "Записывает заказы", "REST API")
Rel(mobile, ones_trade_db, "Записывает заказы", "REST API")
Rel(crm_app, ones_trade_db, "Читает историю покупок", "ODBC")
Rel(ones_trade_db, wms_app, "Выгружает задания на сборку", "Файл")
Rel(ones_trade_db, ones_sd_db, "Проводки", "Внутренняя связь")
Rel(ones_trade_db, ones_doc_db, "Документы", "Внутренняя связь")

@enduml