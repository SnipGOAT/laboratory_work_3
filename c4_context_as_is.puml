@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Context.puml

title Контекстная диаграмма – Текущая архитектура (AS IS) розничного предприятия

' Персоны
Person(customer, "Клиент", "Покупатель в интернет-магазине или офлайн-точке")
Person(manager, "Менеджер", "Управляет операционной деятельностью")

' Системы
System(online_shop, "Интернет-магазин + мобильное приложение", "B2C продажи, каталог, корзина")
System(crm, "CRM-система", "Управление клиентами, заявки, история взаимодействий")
System(wms, "WMS (Warehouse Management System)", "Управление складом, приёмка, отгрузка, остатки")
System(ones_trade, "1С: Торговля", "Оперативный учёт продаж, движение товаров, цены")
System(ones_sd, "1С: Денежные средства", "Учёт денежных потоков, платежи, касса")
System(ones_doc, "1С: Документооборот", "Согласование договоров, накладных, внутренних документов")

' Внешняя система (пока не интегрирована)
System_Ext(brand, "BrandAnalytics", "Мониторинг соцмедиа (отзывы, упоминания) – пока не используется")

' Связи
Rel(customer, online_shop, "Оформляет заказ, просматривает каталог", "HTTPS")
Rel(customer, crm, "Обращается в поддержку", "телефон/email")

Rel(online_shop, ones_trade, "Передаёт заказы в 1С", "REST API")
Rel(online_shop, crm, "Синхронизирует клиентов", "JDBC")

Rel(ones_trade, wms, "Отправляет задания на сборку", "файловый обмен")
Rel(ones_trade, ones_sd, "Формирует финансовые проводки", "JDBC")
Rel(ones_trade, ones_doc, "Генерирует счета-фактуры", "JDBC")

Rel(manager, ones_trade, "Просматривает отчёты по продажам", "встроенный интерфейс")
Rel(manager, crm, "Анализирует клиентскую базу", "встроенный интерфейс")
Rel(manager, wms, "Контролирует остатки на складе", "встроенный интерфейс")

' Примечание о проблемах
note right of ones_trade
  **Проблемы AS IS:**
  - Данные разрознены по разным системам
  - Нет единого источника истины для аналитики
  - Аналитика возможна только в пределах одной системы
  - Прогнозирование спроса отсутствует или субъективно
  - Отзывы из соцмедиа не собираются и не анализируются
end note

@enduml
