<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:process id="ETL_Process_ToBe" name="ETL: сбор данных из всех источников (TO BE)" isExecutable="true">
    
    <!-- Start Event -->
    <bpmn:startEvent id="StartEvent_1" name="Начало ETL">
      <bpmn:outgoing>Flow_to_ParallelGateway</bpmn:outgoing>
    </bpmn:startEvent>
    
    <!-- Parallel Gateway (fork) -->
    <bpmn:parallelGateway id="ParallelGateway_Fork" name="Разветвление по источникам">
      <bpmn:incoming>Flow_to_ParallelGateway</bpmn:incoming>
      <bpmn:outgoing>Flow_to_ExtractWeb</bpmn:outgoing>
      <bpmn:outgoing>Flow_to_ExtractCRM</bpmn:outgoing>
      <bpmn:outgoing>Flow_to_ExtractWMS</bpmn:outgoing>
      <bpmn:outgoing>Flow_to_Extract1C</bpmn:outgoing>
      <bpmn:outgoing>Flow_to_ExtractBrand</bpmn:outgoing>
    </bpmn:parallelGateway>
    
    <!-- Tasks извлечения -->
    <bpmn:serviceTask id="ExtractWeb" name="Извлечь данные из Интернет-магазина (заказы, клики)">
      <bpmn:incoming>Flow_to_ExtractWeb</bpmn:incoming>
      <bpmn:outgoing>Flow_from_ExtractWeb</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="ExtractCRM" name="Извлечь данные из CRM (клиенты, обращения)">
      <bpmn:incoming>Flow_to_ExtractCRM</bpmn:incoming>
      <bpmn:outgoing>Flow_from_ExtractCRM</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="ExtractWMS" name="Извлечь данные из WMS (остатки, движения)">
      <bpmn:incoming>Flow_to_ExtractWMS</bpmn:incoming>
      <bpmn:outgoing>Flow_from_ExtractWMS</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Extract1C" name="Извлечь данные из 1С (продажи, цены, финансы)">
      <bpmn:incoming>Flow_to_Extract1C</bpmn:incoming>
      <bpmn:outgoing>Flow_from_Extract1C</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="ExtractBrand" name="Извлечь отзывы из BrandAnalytics (тональность)">
      <bpmn:incoming>Flow_to_ExtractBrand</bpmn:incoming>
      <bpmn:outgoing>Flow_from_ExtractBrand</bpmn:outgoing>
    </bpmn:serviceTask>
    
    <!-- Parallel Gateway (join) -->
    <bpmn:parallelGateway id="ParallelGateway_Join" name="Сведение потоков">
      <bpmn:incoming>Flow_from_ExtractWeb</bpmn:incoming>
      <bpmn:incoming>Flow_from_ExtractCRM</bpmn:incoming>
      <bpmn:incoming>Flow_from_ExtractWMS</bpmn:incoming>
      <bpmn:incoming>Flow_from_Extract1C</bpmn:incoming>
      <bpmn:incoming>Flow_from_ExtractBrand</bpmn:incoming>
      <bpmn:outgoing>Flow_to_Transform</bpmn:outgoing>
    </bpmn:parallelGateway>
    
    <!-- SubProcess трансформации -->
    <bpmn:subProcess id="TransformSubProcess" name="Трансформация (очистка, нормализация, дедупликация)">
      <bpmn:incoming>Flow_to_Transform</bpmn:incoming>
      <bpmn:outgoing>Flow_from_Transform</bpmn:outgoing>
      <bpmn:startEvent id="SubStart" />
      <bpmn:scriptTask id="Clean" name="Очистка: удаление спецсимволов, приведение регистра" />
      <bpmn:scriptTask id="Normalize" name="Нормализация ФИО, дат, валют" />
      <bpmn:scriptTask id="Deduplicate" name="Дедупликация записей" />
      <bpmn:endEvent id="SubEnd" />
      <bpmn:sequenceFlow id="SubFlow1" sourceRef="SubStart" targetRef="Clean" />
      <bpmn:sequenceFlow id="SubFlow2" sourceRef="Clean" targetRef="Normalize" />
      <bpmn:sequenceFlow id="SubFlow3" sourceRef="Normalize" targetRef="Deduplicate" />
      <bpmn:sequenceFlow id="SubFlow4" sourceRef="Deduplicate" targetRef="SubEnd" />
    </bpmn:subProcess>
    
    <!-- Загрузка в слои DWH -->
    <bpmn:serviceTask id="LoadStaging" name="Загрузить в слой Staging (сырые данные)">
      <bpmn:incoming>Flow_from_Transform</bpmn:incoming>
      <bpmn:outgoing>Flow_to_LoadCore</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="LoadCore" name="Построить Core layer (факты и измерения, SCD Type2)">
      <bpmn:incoming>Flow_to_LoadCore</bpmn:incoming>
      <bpmn:outgoing>Flow_to_LoadMart</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="LoadMart" name="Обновить витрины Mart (агрегаты для BI)">
      <bpmn:incoming>Flow_to_LoadMart</bpmn:incoming>
      <bpmn:outgoing>Flow_to_Log</bpmn:outgoing>
    </bpmn:serviceTask>
    
    <!-- Логирование -->
    <bpmn:serviceTask id="LogTask" name="Записать в лог: количество обработанных записей, ошибки">
      <bpmn:incoming>Flow_to_Log</bpmn:incoming>
      <bpmn:outgoing>Flow_to_End</bpmn:outgoing>
    </bpmn:serviceTask>
    
    <!-- End Event -->
    <bpmn:endEvent id="EndEvent_1" name="Конец ETL">
      <bpmn:incoming>Flow_to_End</bpmn:incoming>
    </bpmn:endEvent>
    
    <!-- Sequence flows (все соединения) -->
    <bpmn:sequenceFlow id="Flow_to_ParallelGateway" sourceRef="StartEvent_1" targetRef="ParallelGateway_Fork" />
    <bpmn:sequenceFlow id="Flow_to_ExtractWeb" sourceRef="ParallelGateway_Fork" targetRef="ExtractWeb" />
    <bpmn:sequenceFlow id="Flow_to_ExtractCRM" sourceRef="ParallelGateway_Fork" targetRef="ExtractCRM" />
    <bpmn:sequenceFlow id="Flow_to_ExtractWMS" sourceRef="ParallelGateway_Fork" targetRef="ExtractWMS" />
    <bpmn:sequenceFlow id="Flow_to_Extract1C" sourceRef="ParallelGateway_Fork" targetRef="Extract1C" />
    <bpmn:sequenceFlow id="Flow_to_ExtractBrand" sourceRef="ParallelGateway_Fork" targetRef="ExtractBrand" />
    
    <bpmn:sequenceFlow id="Flow_from_ExtractWeb" sourceRef="ExtractWeb" targetRef="ParallelGateway_Join" />
    <bpmn:sequenceFlow id="Flow_from_ExtractCRM" sourceRef="ExtractCRM" targetRef="ParallelGateway_Join" />
    <bpmn:sequenceFlow id="Flow_from_ExtractWMS" sourceRef="ExtractWMS" targetRef="ParallelGateway_Join" />
    <bpmn:sequenceFlow id="Flow_from_Extract1C" sourceRef="Extract1C" targetRef="ParallelGateway_Join" />
    <bpmn:sequenceFlow id="Flow_from_ExtractBrand" sourceRef="ExtractBrand" targetRef="ParallelGateway_Join" />
    
    <bpmn:sequenceFlow id="Flow_to_Transform" sourceRef="ParallelGateway_Join" targetRef="TransformSubProcess" />
    <bpmn:sequenceFlow id="Flow_from_Transform" sourceRef="TransformSubProcess" targetRef="LoadStaging" />
    <bpmn:sequenceFlow id="Flow_to_LoadCore" sourceRef="LoadStaging" targetRef="LoadCore" />
    <bpmn:sequenceFlow id="Flow_to_LoadMart" sourceRef="LoadCore" targetRef="LoadMart" />
    <bpmn:sequenceFlow id="Flow_to_Log" sourceRef="LoadMart" targetRef="LogTask" />
    <bpmn:sequenceFlow id="Flow_to_End" sourceRef="LogTask" targetRef="EndEvent_1" />
  </bpmn:process>
  
  <!-- BPMN Diagram (графическое расположение) -->
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="ETL_Process_ToBe">
      <bpmndi:BPMNShape id="StartEvent_1_di" bpmnElement="StartEvent_1">
        <dc:Bounds x="80" y="180" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ParallelGateway_Fork_di" bpmnElement="ParallelGateway_Fork">
        <dc:Bounds x="160" y="175" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ExtractWeb_di" bpmnElement="ExtractWeb">
        <dc:Bounds x="260" y="60" width="120" height="60" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ExtractCRM_di" bpmnElement="ExtractCRM">
        <dc:Bounds x="260" y="130" width="120" height="60" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ExtractWMS_di" bpmnElement="ExtractWMS">
        <dc:Bounds x="260" y="200" width="120" height="60" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Extract1C_di" bpmnElement="Extract1C">
        <dc:Bounds x="260" y="270" width="120" height="60" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ExtractBrand_di" bpmnElement="ExtractBrand">
        <dc:Bounds x="260" y="340" width="120" height="60" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ParallelGateway_Join_di" bpmnElement="ParallelGateway_Join">
        <dc:Bounds x="440" y="175" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="TransformSubProcess_di" bpmnElement="TransformSubProcess" isExpanded="true">
        <dc:Bounds x="540" y="130" width="280" height="140" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="LoadStaging_di" bpmnElement="LoadStaging">
        <dc:Bounds x="880" y="160" width="120" height="60" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="LoadCore_di" bpmnElement="LoadCore">
        <dc:Bounds x="1050" y="160" width="120" height="60" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="LoadMart_di" bpmnElement="LoadMart">
        <dc:Bounds x="1220" y="160" width="120" height="60" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="LogTask_di" bpmnElement="LogTask">
        <dc:Bounds x="1390" y="160" width="120" height="60" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_1_di" bpmnElement="EndEvent_1">
        <dc:Bounds x="1560" y="180" width="36" height="36" />
      </bpmndi:BPMNShape>
      
      <!-- Edges (стрелки) с корректными waypoint'ами -->
      <bpmndi:BPMNEdge id="Edge_Start_Fork" bpmnElement="Flow_to_ParallelGateway">
        <di:waypoint x="116" y="198" />
        <di:waypoint x="160" y="200" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Fork_Web" bpmnElement="Flow_to_ExtractWeb">
        <di:waypoint x="185" y="175" />
        <di:waypoint x="185" y="90" />
        <di:waypoint x="260" y="90" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Fork_CRM" bpmnElement="Flow_to_ExtractCRM">
        <di:waypoint x="185" y="200" />
        <di:waypoint x="260" y="160" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Fork_WMS" bpmnElement="Flow_to_ExtractWMS">
        <di:waypoint x="185" y="225" />
        <di:waypoint x="185" y="230" />
        <di:waypoint x="260" y="230" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Fork_1C" bpmnElement="Flow_to_Extract1C">
        <di:waypoint x="210" y="200" />
        <di:waypoint x="260" y="300" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Fork_Brand" bpmnElement="Flow_to_ExtractBrand">
        <di:waypoint x="210" y="200" />
        <di:waypoint x="260" y="370" />
      </bpmndi:BPMNEdge>
      
      <bpmndi:BPMNEdge id="Edge_Web_Join" bpmnElement="Flow_from_ExtractWeb">
        <di:waypoint x="380" y="90" />
        <di:waypoint x="440" y="200" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_CRM_Join" bpmnElement="Flow_from_ExtractCRM">
        <di:waypoint x="380" y="160" />
        <di:waypoint x="440" y="200" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_WMS_Join" bpmnElement="Flow_from_ExtractWMS">
        <di:waypoint x="380" y="230" />
        <di:waypoint x="440" y="200" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_1C_Join" bpmnElement="Flow_from_Extract1C">
        <di:waypoint x="380" y="300" />
        <di:waypoint x="440" y="200" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Brand_Join" bpmnElement="Flow_from_ExtractBrand">
        <di:waypoint x="380" y="370" />
        <di:waypoint x="440" y="200" />
      </bpmndi:BPMNEdge>
      
      <bpmndi:BPMNEdge id="Edge_Join_Transform" bpmnElement="Flow_to_Transform">
        <di:waypoint x="490" y="200" />
        <di:waypoint x="540" y="200" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Transform_Staging" bpmnElement="Flow_from_Transform">
        <di:waypoint x="820" y="200" />
        <di:waypoint x="880" y="190" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Staging_Core" bpmnElement="Flow_to_LoadCore">
        <di:waypoint x="1000" y="190" />
        <di:waypoint x="1050" y="190" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Core_Mart" bpmnElement="Flow_to_LoadMart">
        <di:waypoint x="1170" y="190" />
        <di:waypoint x="1220" y="190" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Mart_Log" bpmnElement="Flow_to_Log">
        <di:waypoint x="1340" y="190" />
        <di:waypoint x="1390" y="190" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Log_End" bpmnElement="Flow_to_End">
        <di:waypoint x="1510" y="190" />
        <di:waypoint x="1560" y="198" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
