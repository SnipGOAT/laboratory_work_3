@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml

title Контейнерная диаграмма – Текущая архитектура (AS IS)

Person(customer, "Клиент")

System_Boundary(retail_as_is, "Розничное предприятие (AS IS)") {
    Container(web, "Web-сайт", "React, Node.js", "Каталог, корзина, оплата, личный кабинет")
    Container(mobile, "Мобильное приложение", "Kotlin (Android) / Swift (iOS)", "Заказы, уведомления, отслеживание")
    
    Container(crm_app, "CRM-система", "Java + PostgreSQL", "Управление клиентами, заявки, история обращений")
    Container(wms_app, "WMS", "C# + MS SQL Server", "Складские операции, инвентаризация, сборка")
    
    ContainerDb(ones_trade_db, "1С: Торговля", "MS SQL Server", "Товары, продажи, цены, поставщики")
    ContainerDb(ones_sd_db, "1С: Денежные средства", "MS SQL Server", "Платежи, касса, себестоимость")
    ContainerDb(ones_doc_db, "1С: Документооборот", "MS SQL Server", "Договоры, накладные, счета")
}

' Связи между контейнерами
Rel(customer, web, "Использует", "HTTPS")
Rel(customer, mobile, "Использует", "HTTPS")

Rel(web, ones_trade_db, "Записывает заказы, читает цены", "REST API (JSON)")
Rel(mobile, ones_trade_db, "Записывает заказы", "REST API")

Rel(crm_app, ones_trade_db, "Читает историю покупок клиента", "ODBC")
Rel(web, crm_app, "Передаёт данные о регистрации", "REST API")

Rel(ones_trade_db, wms_app, "Выгружает задания на сборку", "Файловый обмен (CSV/XML)")
Rel(ones_trade_db, ones_sd_db, "Формирует проводки", "Внутренняя связь 1С")
Rel(ones_trade_db, ones_doc_db, "Генерирует документы", "Внутренняя связь 1С")

' Примечание
note right of ones_trade_db
  **Характеристики AS IS:**
  - Каждая система имеет свою БД
  - Нет интеграции между CRM и WMS
  - Нет единого хранилища для аналитики
  - Отчёты формируются в каждой системе отдельно
end note

@enduml
