<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_2" targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:process id="SalesForecastProcess" name="Прогнозирование закупок" isExecutable="true">
    <bpmn:startEvent id="StartEvent_1" name="Инициация">
      <bpmn:outgoing>Flow_to_UserTask</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:userTask id="ManagerSelectPeriod" name="Выбрать период и категорию">
      <bpmn:incoming>Flow_to_UserTask</bpmn:incoming>
      <bpmn:outgoing>Flow_to_GetSales</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:serviceTask id="GetSalesData" name="Выгрузить продажи из DWH">
      <bpmn:incoming>Flow_to_GetSales</bpmn:incoming>
      <bpmn:outgoing>Flow_to_GetSocial</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="GetSocialData" name="Получить тональность отзывов">
      <bpmn:incoming>Flow_to_GetSocial</bpmn:incoming>
      <bpmn:outgoing>Flow_to_RunML</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="RunMLModel" name="Запустить модель прогноза">
      <bpmn:incoming>Flow_to_RunML</bpmn:incoming>
      <bpmn:outgoing>Flow_to_SaveForecast</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="SaveForecast" name="Сохранить прогноз в витрину">
      <bpmn:incoming>Flow_to_SaveForecast</bpmn:incoming>
      <bpmn:outgoing>Flow_to_Review</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:userTask id="ReviewForecast" name="Утвердить закупку">
      <bpmn:incoming>Flow_to_Review</bpmn:incoming>
      <bpmn:outgoing>Flow_to_End</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:endEvent id="EndEvent_1" name="Завершение">
      <bpmn:incoming>Flow_to_End</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_to_UserTask" sourceRef="StartEvent_1" targetRef="ManagerSelectPeriod" />
    <bpmn:sequenceFlow id="Flow_to_GetSales" sourceRef="ManagerSelectPeriod" targetRef="GetSalesData" />
    <bpmn:sequenceFlow id="Flow_to_GetSocial" sourceRef="GetSalesData" targetRef="GetSocialData" />
    <bpmn:sequenceFlow id="Flow_to_RunML" sourceRef="GetSocialData" targetRef="RunMLModel" />
    <bpmn:sequenceFlow id="Flow_to_SaveForecast" sourceRef="RunMLModel" targetRef="SaveForecast" />
    <bpmn:sequenceFlow id="Flow_to_Review" sourceRef="SaveForecast" targetRef="ReviewForecast" />
    <bpmn:sequenceFlow id="Flow_to_End" sourceRef="ReviewForecast" targetRef="EndEvent_1" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_2">
    <bpmndi:BPMNPlane id="BPMNPlane_2" bpmnElement="SalesForecastProcess">
      <bpmndi:BPMNShape id="StartEvent_1_di" bpmnElement="StartEvent_1">
        <dc:Bounds x="100" y="180" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ManagerSelectPeriod_di" bpmnElement="ManagerSelectPeriod">
        <dc:Bounds x="190" y="160" width="100" height="60" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="GetSalesData_di" bpmnElement="GetSalesData">
        <dc:Bounds x="340" y="160" width="100" height="60" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="GetSocialData_di" bpmnElement="GetSocialData">
        <dc:Bounds x="490" y="160" width="100" height="60" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="RunMLModel_di" bpmnElement="RunMLModel">
        <dc:Bounds x="640" y="160" width="100" height="60" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="SaveForecast_di" bpmnElement="SaveForecast">
        <dc:Bounds x="790" y="160" width="100" height="60" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ReviewForecast_di" bpmnElement="ReviewForecast">
        <dc:Bounds x="940" y="160" width="100" height="60" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_1_di" bpmnElement="EndEvent_1">
        <dc:Bounds x="1090" y="180" width="36" height="36" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_to_UserTask_edge" bpmnElement="Flow_to_UserTask">
        <di:waypoint x="136" y="198" />
        <di:waypoint x="190" y="190" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_to_GetSales_edge" bpmnElement="Flow_to_GetSales">
        <di:waypoint x="290" y="190" />
        <di:waypoint x="340" y="190" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_to_GetSocial_edge" bpmnElement="Flow_to_GetSocial">
        <di:waypoint x="440" y="190" />
        <di:waypoint x="490" y="190" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_to_RunML_edge" bpmnElement="Flow_to_RunML">
        <di:waypoint x="590" y="190" />
        <di:waypoint x="640" y="190" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_to_SaveForecast_edge" bpmnElement="Flow_to_SaveForecast">
        <di:waypoint x="740" y="190" />
        <di:waypoint x="790" y="190" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_to_Review_edge" bpmnElement="Flow_to_Review">
        <di:waypoint x="890" y="190" />
        <di:waypoint x="940" y="190" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_to_End_edge" bpmnElement="Flow_to_End">
        <di:waypoint x="1040" y="190" />
        <di:waypoint x="1090" y="198" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>